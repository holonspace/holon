# ── Proxy Domain Configuration ───────────────────────────────────────────────
# 修改這裡的設定即可套用到 nginx、setup.sh、setup.ps1
# ─────────────────────────────────────────────────────────────────────────────

BASE_DOMAIN=holon.dev

# Subdomains (留空代表使用 BASE_DOMAIN 本身)
WEB_SUBDOMAIN=
AUTH_SUBDOMAIN=auth
API_SUBDOMAIN=api

# Backend ports
WEB_PORT=3000
AUTH_PORT=5173
API_PORT=8787
